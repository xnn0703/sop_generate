{#- 单个工序详情页（横向 A3，齐头分页：每页各字段独立切片）-#}
{#- 输入：proc（含 _proc_index / _sub_index / _sub_total / _is_continuation / _ops_chunk / _notes_chunk / _tools_chunk / _mats_chunk / _images_chunk / _*_start_index）-#}
{%- set sub_total = proc._sub_total -%}
{%- set sub_index = proc._sub_index -%}
{%- set is_cont   = proc._is_continuation -%}
{%- set images = proc._images_chunk -%}
{%- set n_imgs = images | length -%}
<section class="page page-landscape">
  <div class="sheet">
  <table class="proc">
    <colgroup>
      <col style="width:14%"><col style="width:14%"><col style="width:14%">
      <col style="width:18%"><col style="width:14%"><col style="width:6%">
      <col style="width:8%"><col style="width:12%">
    </colgroup>
    <tr>
      <td rowspan="2" class="title-cell">{{ product.model }}<br>作业指导书</td>
      <td class="h-label">产品名称</td>
      <td class="h-label">产品型号</td>
      <td class="h-label">工　序</td>
      <td class="h-label">文件编号</td>
      <td class="h-label">版本</td>
      <td class="h-label">页数</td>
      <td class="h-label">制订时间</td>
    </tr>
    <tr>
      <td class="h-value">{{ product.name }}</td>
      <td class="h-value">{{ product.model }}</td>
      <td class="h-value">
        {{ proc.name }}{% if proc.key %} <span class="star">★</span>{% endif %}
        {%- if sub_total > 1 %} <small>（{{ sub_index }}/{{ sub_total }}）</small>{% endif %}
      </td>
      <td class="h-value">{{ product.doc_id }}</td>
      <td class="h-value">{{ product.version }}</td>
      <td class="h-value">{{ proc._proc_index }} / {{ total }}</td>
      <td class="h-value">{{ product.publish_date }}</td>
    </tr>

    <tr>
      <td class="ops-cell ops-main" colspan="3">
        <div class="sec-title">
          操作说明{% if sub_total > 1 %}（{{ sub_index }}/{{ sub_total }}）{% endif %}：
        </div>
        {%- if proc._ops_chunk %}
        <ol start="{{ proc._ops_start_index }}">
          {%- for op in proc._ops_chunk %}
          <li>{{ op }}</li>
          {%- endfor %}
        </ol>
        {%- else %}
        <div class="cont-overlay">（无内容）</div>
        {%- endif %}
      </td>
      <td class="pic-cell imgs-{{ n_imgs }}" colspan="5" rowspan="3">
        {%- if n_imgs == 0 %}
        &nbsp;
        {%- elif n_imgs == 1 %}
        <img src="{{ image_base }}/{{ images[0] }}" alt="{{ proc.name }}">
        {%- else %}
        <div class="imgs">
          {%- for img in images %}
          <img src="{{ image_base }}/{{ img }}" alt="{{ proc.name }}-{{ loop.index }}">
          {%- endfor %}
        </div>
        {%- endif %}
      </td>
    </tr>

    <tr>
      <td class="ops-cell ops-note" colspan="3">
        <div class="sec-title">
          注意事项{% if sub_total > 1 and proc._notes_chunk %}（{{ sub_index }}/{{ sub_total }}）{% endif %}：
        </div>
        {%- if proc._notes_chunk %}
        <div class="notes">
          {%- for note in proc._notes_chunk %}
          <p>{{ (proc._notes_start_index + loop.index0) | circled }} {{ note }}</p>
          {%- endfor %}
        </div>
        {%- endif %}
      </td>
    </tr>

    <tr>
      <td class="mat-cell" colspan="3">
        <table class="mat">
          {%- set tools_chunk = proc._tools_chunk %}
          {%- set mats_chunk  = proc._mats_chunk %}
          {%- for i in range(4) %}
          <tr>
            {%- if loop.first %}<td class="cat" rowspan="4">工具设备</td>{%- endif %}
            <td class="idx">{{ proc._tools_start_index + i }}</td>
            <td class="txt">{{ tools_chunk[i] if i < (tools_chunk | length) else '' }}</td>
            {%- if loop.first %}<td class="cat" rowspan="4">作业材料</td>{%- endif %}
            <td class="idx">{{ proc._mats_start_index + i }}</td>
            <td class="txt">{{ mats_chunk[i] if i < (mats_chunk | length) else '' }}</td>
          </tr>
          {%- endfor %}
        </table>
      </td>
    </tr>
  </table>

  <table class="sign">
    <tr>
      <td class="label">编制</td><td>&nbsp;</td>
      <td class="label">审核</td><td>&nbsp;</td>
      <td class="label">核准</td><td>&nbsp;</td>
      <td class="label">日期</td><td>{{ product.publish_date }}</td>
    </tr>
  </table>
  </div>
</section>
