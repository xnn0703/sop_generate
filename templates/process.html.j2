{#- 单个工序详情/摘要页（横向 A3）-#}
{#- detail：齐头分页；summary：父级无内容但有子级时的工序组摘要页 -#}
{%- set sub_total = proc._sub_total -%}
{%- set sub_index = proc._sub_index -%}
{%- set images = proc._images_chunk -%}
{%- set n_imgs = images | length -%}
<section class="page page-landscape" id="proc-{{ proc._proc_number }}-{{ sub_index }}">
  <div class="sheet">
  <table class="proc">
    <colgroup>
      <col style="width:12%"><col style="width:11%"><col style="width:11%">
      <col style="width:9%"><col style="width:18%"><col style="width:9%">
      <col style="width:12%"><col style="width:5%"><col style="width:5%">
      <col style="width:8%">
    </colgroup>
    <tr>
      <td rowspan="2" class="title-cell">{{ product.model }}<br>作业指导书</td>
      <td class="h-label">产品名称</td>
      <td class="h-label">产品型号</td>
      <td class="h-label">工序编号</td>
      <td class="h-label">工　序</td>
      <td class="h-label">标准工时</td>
      <td class="h-label">文件编号</td>
      <td class="h-label">版本</td>
      <td class="h-label">页数</td>
      <td class="h-label">制订时间</td>
    </tr>
    <tr>
      <td class="h-value">{{ product.name }}</td>
      <td class="h-value">{{ product.model }}</td>
      <td class="h-value">{{ proc._proc_number }}</td>
      <td class="h-value">
        {{ proc.name }}{% if proc.key %} <span class="star">★</span>{% endif %}
        {%- if sub_total > 1 %} <small>（{{ sub_index }}/{{ sub_total }}）</small>{% endif %}
      </td>
      <td class="h-value">{{ proc._work_time_text }}</td>
      <td class="h-value">{{ product.doc_id }}</td>
      <td class="h-value">{{ product.version }}</td>
      <td class="h-value">{{ proc._proc_number }} / {{ total }}</td>
      <td class="h-value">{{ product.publish_date }}</td>
    </tr>

    {%- if proc._page_type == 'summary' %}
    <tr>
      <td class="summary-cell" colspan="10">
        <div class="summary-title">{{ proc._proc_number }} {{ proc.name }}{% if proc.key %} <span class="star">★</span>{% endif %} · 子工序摘要</div>
        <table class="summary-table">
          <tr>
            <th style="width:16%;">工序编号</th>
            <th style="width:44%;">工序名称</th>
            <th style="width:16%;">标准工时</th>
            <th style="width:12%;">关键</th>
            <th style="width:12%;">层级</th>
          </tr>
          {%- for child in proc._children_summary %}
          <tr>
            <td>{{ child._proc_number }}</td>
            <td class="summary-name level-{{ child._level }}">{{ child.name }}</td>
            <td>{{ child._work_time_text }}</td>
            <td>{% if child.key %}<span class="star">★</span>{% endif %}</td>
            <td>{{ child._level }} 级</td>
          </tr>
          {%- endfor %}
        </table>
      </td>
    </tr>
    {%- else %}
    <tr>
      <td class="ops-cell ops-main" colspan="4">
        <div class="sec-title">
          操作说明{% if sub_total > 1 %}（{{ sub_index }}/{{ sub_total }}）{% endif %}：
        </div>
        {%- if proc._ops_chunk %}
        <ol start="{{ proc._ops_start_index }}">
          {%- for op in proc._ops_chunk %}
          <li>{{ op }}</li>
          {%- endfor %}
        </ol>
        {%- else %}
        <div class="cont-overlay">（待填写）</div>
        {%- endif %}
      </td>
      <td class="pic-cell imgs-{{ n_imgs }}{% if proc._manual_images %} manual-layout{% endif %}" colspan="6" rowspan="3">
        {%- if n_imgs == 0 %}
        &nbsp;
        {%- elif proc._manual_images %}
        <div class="img-canvas">
          {%- for img in images %}
          <div class="manual-img-box" data-rotation="{{ img._layout.rotation | default(0) }}" style="left:{{ img._layout.x }}%; top:{{ img._layout.y }}%; width:{{ img._layout.w }}%; height:{{ img._layout.h }}%;">
            <img src="{{ img._src }}" alt="{{ proc.name }}-{{ loop.index }}">
          </div>
          {%- endfor %}
        </div>
        {%- elif n_imgs == 1 %}
        <img src="{{ images[0]._src }}" alt="{{ proc.name }}">
        {%- else %}
        <div class="imgs">
          {%- for img in images %}
          <img src="{{ img._src }}" alt="{{ proc.name }}-{{ loop.index }}">
          {%- endfor %}
        </div>
        {%- endif %}
      </td>
    </tr>

    <tr>
      <td class="ops-cell ops-note" colspan="4">
        <div class="sec-title">
          注意事项{% if sub_total > 1 and proc._notes_chunk %}（{{ sub_index }}/{{ sub_total }}）{% endif %}：
        </div>
        {%- if proc._notes_chunk %}
        <div class="notes">
          {%- for note in proc._notes_chunk %}
          <p>{{ (proc._notes_start_index + loop.index0) | circled }} {{ note }}</p>
          {%- endfor %}
        </div>
        {%- endif %}
      </td>
    </tr>

    <tr>
      <td class="mat-cell" colspan="4">
        <table class="mat">
          {%- set tools_chunk = proc._tools_chunk %}
          {%- set mats_chunk  = proc._mats_chunk %}
          {%- for i in range(4) %}
          <tr>
            {%- if loop.first %}<td class="cat" rowspan="4">工具设备</td>{%- endif %}
            <td class="idx">{{ proc._tools_start_index + i }}</td>
            <td class="txt">{{ tools_chunk[i] if i < (tools_chunk | length) else '' }}</td>
            {%- if loop.first %}<td class="cat" rowspan="4">作业材料</td>{%- endif %}
            <td class="idx">{{ proc._mats_start_index + i }}</td>
            <td class="txt">{{ mats_chunk[i] if i < (mats_chunk | length) else '' }}</td>
          </tr>
          {%- endfor %}
        </table>
      </td>
    </tr>
    {%- endif %}
  </table>

  <table class="sign">
    <tr>
      <td class="label">编制</td><td>&nbsp;</td>
      <td class="label">审核</td><td>&nbsp;</td>
      <td class="label">核准</td><td>&nbsp;</td>
      <td class="label">日期</td><td>{{ product.publish_date }}</td>
    </tr>
  </table>
  </div>
</section>
