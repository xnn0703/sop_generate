{#- 工艺流程图（多级工序：主流程 + 组内展开，可分页）-#}
{#- 输入：product, processes（全量）, flow_chunk, flow_index, flow_total -#}
<section class="page page-portrait">
  <table class="head">
    <tr class="company-row"><td colspan="6">{{ product.company }}</td></tr>
    <tr>
      <td class="label">文件名称</td><td class="value">{{ product.model }}作业指导书</td>
      <td class="label">文件编号</td><td class="value">{{ product.doc_id }}</td>
      <td class="label">版　次</td><td class="value">{{ product.version }}</td>
    </tr>
    <tr>
      <td class="label">编制</td><td class="value">&nbsp;</td>
      <td class="label">审核</td><td class="value">&nbsp;</td>
      <td class="label">核准</td><td class="value">&nbsp;</td>
    </tr>
    <tr>
      <td class="label">发布日期</td><td class="value">{{ product.publish_date }}</td>
      <td class="label">实行日期</td><td class="value">{{ product.effective_date }}</td>
      <td class="label">页数</td><td class="value">{{ flow_index }} / {{ flow_total }}</td>
    </tr>
  </table>

  <div class="flow-title">
    {{ product.model }} 工艺流程{% if flow_total > 1 %}（{{ flow_index }}/{{ flow_total }}）{% endif %}
  </div>

  <div class="flow">
    {%- if flow_index > 1 %}
    <div class="cont-mark">↑ 接上页</div>
    <div class="arrow">↓</div>
    {%- endif %}

    {%- for proc in flow_chunk %}
      {%- if proc._level == 1 %}
      <div class="flow-group">
        <div class="node main-node">{{ proc._proc_number }} {{ proc.name }}{% if proc.key %} <span class="star">★</span>{% endif %}</div>
        {%- if proc._has_children %}
        <div class="children">
        {%- endif %}
      {%- else %}
          <div class="child-node level-{{ proc._level }}">{{ proc._proc_number }} {{ proc.name }}{% if proc.key %} <span class="star">★</span>{% endif %}</div>
      {%- endif %}

      {%- set next_proc = flow_chunk[loop.index] if not loop.last else none %}
      {%- if proc._level == 1 and not proc._has_children %}
      </div>
        {%- if not loop.last %}
      <div class="arrow">↓</div>
        {%- endif %}
      {%- elif proc._level > 1 and (next_proc is none or next_proc._level == 1) %}
        </div>
      </div>
        {%- if not loop.last %}
      <div class="arrow">↓</div>
        {%- endif %}
      {%- endif %}
    {%- endfor %}

    {%- if flow_index < flow_total %}
    <div class="arrow">↓</div>
    <div class="cont-mark">续下页</div>
    {%- elif (processes | selectattr('key') | list) %}
    <div class="note">注：<span class="star">★</span> 为关键工序</div>
    {%- endif %}
  </div>
</section>
