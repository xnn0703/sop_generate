/* ===== 打印分页：纵向 / 横向命名页（A3）=====
   @page margin 必须为 0，否则 .page 会被双重缩放（边距由 .page 自己的 padding 控制） */
@page portrait  { size: A3 portrait;  margin: 0; }
@page landscape { size: A3 landscape; margin: 0; }
.page-portrait  { page: portrait; }
.page-landscape { page: landscape; }

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  font-family: "FangSong", "仿宋", "FangSong_GB2312", "SimSun", "宋体", serif;
  font-size: 13pt;
  color: #000;
  background: #e8e8e8;
}

/* 屏幕预览：模拟纸张 */
.page {
  margin: 8mm auto;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  page-break-after: always;
  break-after: page;
  page-break-inside: avoid;
  break-inside: avoid;
  overflow: hidden;
  position: relative;
}
.page-portrait  { width: 297mm; height: 420mm; padding: 20mm 18mm; }
.page-landscape { width: 420mm; height: 297mm; padding: 14mm 16mm; }
.page:last-child { page-break-after: auto; break-after: auto; }

@media print {
  body { background: #fff; }
  .page { margin: 0; box-shadow: none; }
  /* width/height/padding 保持，与 @page 物理尺寸 1:1 对齐 */
}

/* 防止任何内部表格被分页拆开 */
table, tr, td { page-break-inside: avoid; break-inside: avoid; }

/* ===== 封面 ===== */
.cover { text-align: center; padding-top: 35mm; }
.cover .company {
  font-family: "FangSong_GB2312", "仿宋", serif;
  font-size: 40pt; font-weight: bold; color: #339966;
  margin-bottom: 50mm; letter-spacing: 6px;
}
.cover .model {
  font-size: 64pt; font-weight: bold; color: #0000FF;
  letter-spacing: 8px; line-height: 1.4;
}
.cover .doc-title {
  font-size: 64pt; font-weight: bold; color: #0000FF;
  letter-spacing: 16px; margin-bottom: 40mm;
}
.cover .doc-info { font-size: 18pt; line-height: 2.4; margin-top: 14mm; }
.cover .controlled { margin-top: 20mm; font-size: 18pt; }
.cover .controlled-box {
  display: inline-block; border: 1.5pt solid #000;
  padding: 5mm 24mm; margin-top: 5mm;
}
.cover .signers, .cover .dates {
  margin-top: 22mm; font-size: 16pt;
  display: flex; justify-content: space-around;
}
.cover .dates { margin-top: 14mm; }

/* ===== 公司表头（纵向页用） ===== */
table.head {
  width: 100%; border-collapse: collapse;
  margin-bottom: 6mm; font-size: 13pt;
}
table.head td {
  border: 1pt solid #000; text-align: center;
  padding: 2mm 3mm; height: 11mm;
}
table.head .company-row td {
  font-family: "FangSong_GB2312", "仿宋", serif;
  font-size: 20pt; font-weight: bold;
  color: #339966; height: 16mm;
}
table.head .label { background: #f3f3f3; font-weight: bold; width: 12%; }
table.head .value { width: 21%; }

/* ===== 目录表 ===== */
table.toc {
  width: 100%; border-collapse: collapse;
  margin-top: 6mm; font-size: 14pt;
}
table.toc th, table.toc td {
  border: 1pt solid #000; padding: 3.5mm 3mm;
  text-align: center; height: 12mm;
}
table.toc th { background: #f3f3f3; font-weight: bold; }
table.toc .toc-name { text-align: left; }
table.toc .toc-name.level-1 { padding-left: 6mm; font-weight: bold; }
table.toc .toc-name.level-2 { padding-left: 14mm; }
table.toc .toc-name.level-3 { padding-left: 24mm; font-size: 13pt; }

/* ===== 工艺流程图 ===== */
.flow-title {
  text-align: center; font-size: 24pt; font-weight: bold;
  color: #0000FF; margin: 10mm 0 14mm 0;
}
.flow { display: flex; flex-direction: column; align-items: center; }
.flow .node {
  width: 110mm; padding: 5mm 6mm;
  border: 1.5pt solid #000; background: #eaf4ff;
  text-align: center; font-size: 16pt; font-weight: bold;
}
.flow .flow-group {
  width: 150mm;
  border: 1.2pt solid #000;
  background: #fff;
  padding: 3mm;
}
.flow .flow-group .main-node {
  width: 100%;
  margin: 0 auto;
}
.flow .children {
  margin-top: 3mm;
  border-top: 0.8pt dashed #999;
  padding-top: 2mm;
}
.flow .child-node {
  border: 0.8pt solid #777;
  background: #f7fbff;
  padding: 2mm 3mm;
  margin: 1.5mm 0;
  font-size: 12.5pt;
  text-align: left;
}
.flow .child-node.level-2 { margin-left: 7mm; }
.flow .child-node.level-3 { margin-left: 18mm; font-size: 11.5pt; }
.flow .arrow { font-size: 20pt; margin: 2mm 0; }
.flow .note { margin-top: 10mm; font-size: 13pt; color: #555; }
.flow .cont-mark {
  font-size: 14pt; color: #888; font-weight: bold;
  margin: 2mm 0; letter-spacing: 2px;
}

/* =========================================================
   工序详情页（横向 A3，表格铺满）
   ========================================================= */
.sheet {
  page-break-inside: avoid;
  break-inside: avoid;
  height: 100%;
  display: flex;
  flex-direction: column;
}
table.proc {
  width: 100%;
  border-collapse: collapse;
  font-size: 13pt;
  table-layout: fixed;
  flex: 1;
}
table.proc td {
  border: 1pt solid #000;
  padding: 3mm 4mm;
  vertical-align: top;
}

/* 表头行 */
table.proc .title-cell {
  font-family: "FangSong_GB2312", "仿宋", serif;
  font-weight: bold; color: #339966;
  font-size: 18pt; text-align: center;
  vertical-align: middle; width: 14%;
}
table.proc .h-label {
  background: #f3f3f3; font-weight: bold;
  text-align: center; vertical-align: middle; height: 10mm;
  font-size: 12pt;
}
table.proc .h-value {
  text-align: center; vertical-align: middle; height: 10mm;
  font-size: 12pt;
}

/* 父级工序摘要页 */
table.proc .summary-cell {
  height: 188mm;
  padding: 8mm 10mm;
}
table.proc .summary-title {
  font-size: 18pt;
  font-weight: bold;
  text-align: center;
  margin: 4mm 0 8mm;
}
table.summary-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
  font-size: 13pt;
}
table.summary-table th,
table.summary-table td {
  border: 1pt solid #000;
  padding: 3mm;
  height: 12mm;
  text-align: center;
  vertical-align: middle;
}
table.summary-table th { background: #f3f3f3; font-weight: bold; }
table.summary-table .summary-name { text-align: left; }
table.summary-table .summary-name.level-2 { padding-left: 10mm; }
table.summary-table .summary-name.level-3 { padding-left: 22mm; }

/* 操作说明 / 注意事项（左半） */
table.proc .ops-cell { width: 42%; vertical-align: top; overflow: hidden; }
table.proc .ops-cell.ops-main { height: 110mm; }
table.proc .ops-cell.ops-note { height: 75mm; }
table.proc .ops-cell .sec-title {
  font-weight: bold; margin-bottom: 3mm; font-size: 14pt;
}
table.proc .ops-cell ol { margin: 0; padding-left: 7mm; }
table.proc .ops-cell ol li { line-height: 1.9; margin-bottom: 1mm; font-size: 13pt; }
table.proc .ops-cell .notes p { margin: 1mm 0; line-height: 1.9; font-size: 13pt; }

/* 图片（右半） */
table.proc .pic-cell {
  text-align: center; vertical-align: middle;
  background: #fff; padding: 3mm;
  height: 188mm;
  overflow: hidden;
}
table.proc .pic-cell img {
  max-width: 100%; object-fit: contain;
}
/* 1 张：单图填满 */
table.proc .pic-cell.imgs-1 img { max-height: 188mm; }

/* 2 张：上下两张 */
table.proc .pic-cell.imgs-2 .imgs {
  display: flex; flex-direction: column;
  gap: 2mm; align-items: center;
  height: 100%;
}
table.proc .pic-cell.imgs-2 img { max-height: 92mm; }

/* 3-4 张：2×2 网格，每张自动缩放至格子大小 */
table.proc .pic-cell.imgs-3 .imgs,
table.proc .pic-cell.imgs-4 .imgs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 2mm;
  height: 100%;
  align-items: center;
  justify-items: center;
}
table.proc .pic-cell.imgs-3 img,
table.proc .pic-cell.imgs-4 img {
  max-width: 100%; max-height: 92mm;
  width: auto; height: auto;
}

table.proc .pic-cell .cont-overlay {
  color: #888; font-size: 14pt; padding: 30mm 0;
}

/* 手动图片布局：只能在右侧图片画布内定位 */
table.proc .pic-cell.manual-layout { padding: 0; }
table.proc .pic-cell .img-canvas {
  position: relative;
  width: 100%;
  height: 188mm;
  overflow: hidden;
  background: #fff;
}
table.proc .pic-cell .manual-img-box {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
table.proc .pic-cell .manual-img-box img {
  max-width: 100%;
  max-height: 100%;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* 工具设备 / 作业材料 — 子表格 */
table.proc .mat-cell { padding: 0; }
table.mat {
  width: 100%; border-collapse: collapse;
  font-size: 11.5pt; table-layout: fixed;
}
table.mat td {
  border: 1pt solid #000; padding: 1.5mm 2.5mm;
  height: 10mm; line-height: 1.3;
  text-align: center; vertical-align: middle; overflow: hidden;
}
table.mat td.cat {
  width: 10mm; background: #f3f3f3; font-weight: bold;
  writing-mode: vertical-rl; text-orientation: upright;
  letter-spacing: 3px; font-size: 13pt;
}
table.mat td.idx { width: 8mm; }
table.mat td.txt { text-align: center; }

/* 签字行 */
table.sign {
  width: 100%; border-collapse: collapse;
  border-top: none; font-size: 12pt; margin-top: -1px;
}
table.sign td {
  border: 1pt solid #000; padding: 2.5mm 3mm;
  height: 13mm; text-align: center;
}
table.sign .label { background: #f3f3f3; font-weight: bold; width: 7%; }

.star { color: #c00; font-weight: bold; }
